# OpenVPN Manager Configuration
# Copy this file to .env and fill in your values

# Server 1
VPN_SERVER_1_NAME=Production VPN
VPN_SERVER_1_HOST=3.68.110.36
VPN_SERVER_1_USER=ubuntu
VPN_SERVER_1_KEY_PATH=/path/to/your/key.pem
VPN_SERVER_1_SCRIPT_PATH=/vpn/setup_open_vpn.sh
VPN_SERVER_1_OVPN_DIR=/home/ubuntu

# Server 2
VPN_SERVER_2_NAME=Staging VPN
VPN_SERVER_2_HOST=
VPN_SERVER_2_USER=ubuntu
VPN_SERVER_2_KEY_PATH=/path/to/your/key.pem
VPN_SERVER_2_SCRIPT_PATH=/vpn/setup_open_vpn.sh
VPN_SERVER_2_OVPN_DIR=/home/ubuntu

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth (Google SSO)
JWT_SECRET=super-secret-change-me-in-production
DATA_DIR=./data

# Google OAuth Client ID (from Google Cloud Console > APIs & Services > Credentials).
# Required for sign-in to work.
GOOGLE_CLIENT_ID=

# Optional comma-separated list of email domains allowed to sign in.
# Empty = any Google account allowed. The first user to ever sign in is
# automatically promoted to 'admin'; everyone else starts as 'viewer'
# until an admin promotes them on the Admin page.
ALLOWED_EMAIL_DOMAINS=

# Slack
SLACK_BOT_TOKEN=
